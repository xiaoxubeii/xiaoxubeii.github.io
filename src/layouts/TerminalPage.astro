---
import '../styles/global.css';

const {
  title,
  command,
  description = 'beixu personal command-line site',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={`${title} | beixu code`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/site-preview.svg" />
    <title>{title} | beixu code</title>
  </head>
  <body>
    <div class="terminal-page">
      <main>
        <section class="subpage-frame" aria-labelledby="page-title">
          <div class="frame-title">
            <a href="/">beixu code</a>
            <span class="muted">v0.2.0</span>
          </div>

          <header class="subpage-header">
            <p class="command-line">{command}</p>
            <h1 id="page-title">{title}</h1>
            <p>{description}</p>
          </header>

          <slot />
        </section>

        <section class="input-strip" aria-label="Command prompt">
          <span class="chevron">&gt;</span>
          <span class="cursor" aria-hidden="true"></span>
        </section>
      </main>
    </div>
  </body>
</html>
