---
import '../styles/global.css';

const recent = [
  'Built AI infrastructure, agent workflows, and cloud-native platforms at enterprise scale',
  'Now shipping AI agents, embodied intelligence, clinical AI, and automated research systems into the real world',
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="beixu's command-line inspired personal homepage for AI agents, research automation, and context engineering."
    />
    <meta property="og:title" content="beixu code" />
    <meta
      property="og:description"
      content="A Claude Code and Codex inspired personal homepage."
    />
    <meta property="og:image" content="/site-preview.svg" />
    <title>beixu code</title>
  </head>
  <body>
    <div class="terminal-page">
      <main>
        <section class="boot-frame" aria-labelledby="home-title">
          <div class="frame-title">
            <span>beixu code</span>
            <span class="muted">v0.2.0</span>
          </div>

          <div class="boot-grid">
            <section class="welcome-pane" aria-labelledby="home-title">
              <div>
                <p class="welcome">Welcome back!</p>
                <img
                  class="pixel-bust"
                  src="/avatar-pixel-bust.png"
                  alt="Pixel-style half-body avatar of beixu"
                />
                <h1 id="home-title">beixu</h1>
                <p class="muted">AI Systems · Agents · Applied Intelligence</p>
                <p class="path">/Users/beixu</p>
              </div>
            </section>

            <section class="activity-pane" aria-label="Active mission and profile">
              <div class="terminal-block">
                <p class="section-title">Active mission</p>
                <p class="intro-copy">
                  AI architect and product builder turning research-grade
                  intelligence into deployable systems.
                </p>
              </div>

              <div class="rule"></div>

              <div class="terminal-block">
                <p class="section-title">What's loaded</p>
                {recent.map((item) => (
                  <p class="truncate-line">{item}</p>
                ))}
                <p class="muted command-links">
                  <a href="/about">/about</a> for who I am,
                  <a href="/work">/work</a> for things I've built,
                  <a href="/notes">/notes</a> for writing,
                  <a href="/now">/now</a> for current focus,
                  <a href="/contact">/contact</a> to reach me
                </p>
              </div>
            </section>
          </div>
        </section>

        <section class="session-lines" aria-label="Session status">
          <p>
            <span class="green">*</span> Running loop: research -&gt; systems -&gt;
            products -&gt; real-world deployment
          </p>
          <p class="warning">
            Status: available for startup teams building serious AI infrastructure
            and applied intelligence
          </p>
        </section>

        <section class="command-console" aria-label="Interactive command output">
          <div id="command-output" class="command-output" aria-live="polite">
            <p>
              <span class="green">*</span> Try: help, work, startup-fit,
              why-ai, contact
            </p>
          </div>
        </section>

        <section class="input-strip interactive" aria-label="Command prompt">
          <form id="command-form" class="command-form" autocomplete="off">
            <label class="chevron" for="command-input">&gt;</label>
            <input
              id="command-input"
              name="command"
              type="text"
              inputmode="text"
              spellcheck="false"
              aria-label="Type a command"
            />
          </form>
        </section>
      </main>
    </div>

    <script>
      const form = document.querySelector('#command-form');
      const input = document.querySelector('#command-input');
      const output = document.querySelector('#command-output');
      const measure = document.createElement('canvas').getContext('2d');

      const responses = {
        help: [
          'commands: about, work, why-ai, startup-fit, contact, clear',
          'paths: /about /work /notes /now /contact',
        ],
        about: [
          'AI architect and product builder turning research-grade intelligence into deployable systems.',
          'focus: cloud infra, agents, embodied intelligence, clinical AI.',
        ],
        work: [
          'work map: agentic systems, embodied intelligence, clinical AI + CPET, AI infrastructure.',
          'open: /work',
        ],
        'why-ai': [
          'because useful AI needs systems: compute, data, agents, interfaces, review loops, and deployment.',
        ],
        'startup-fit': [
          'best fit: serious applied AI teams building infrastructure, agent workflows, robotics intelligence, or clinical decision support.',
        ],
        contact: ['github.com/xiaoxubeii', 'xiaoxubeii@gmail.com'],
      };

      const pathCommands = new Set(['about', 'work', 'contact']);

      const appendLine = (text, className = '') => {
        const line = document.createElement('p');
        if (className) line.className = className;
        line.textContent = text;
        output?.append(line);
      };

      const updateCursor = () => {
        if (!form || !input || !measure) return;
        const style = window.getComputedStyle(input);
        measure.font = style.font;
        const position = input.selectionStart ?? input.value.length;
        const text = input.value.slice(0, position);
        const width = measure.measureText(text).width;
        form.style.setProperty('--cursor-offset', `${Math.ceil(width)}px`);
      };

      input?.addEventListener('input', updateCursor);
      input?.addEventListener('keyup', updateCursor);
      input?.addEventListener('click', updateCursor);
      input?.addEventListener('focus', updateCursor);
      window.addEventListener('resize', updateCursor);
      updateCursor();

      form?.addEventListener('submit', (event) => {
        event.preventDefault();
        const command = input.value.trim().toLowerCase();
        if (!command) return;

        appendLine(`> ${command}`, 'command-echo');
        input.value = '';
        updateCursor();

        if (command === 'clear') {
          output.innerHTML = '';
          appendLine('* console cleared', 'green');
          return;
        }

        const normalized = command.replace(/^\//, '');
        const reply = responses[normalized];

        if (!reply) {
          appendLine(`unknown command: ${command}`);
          appendLine('try: help');
          return;
        }

        reply.forEach((line) => appendLine(line));

        if (pathCommands.has(normalized)) {
          const link = document.createElement('a');
          link.href = `/${normalized}`;
          link.textContent = `open /${normalized}`;
          const row = document.createElement('p');
          row.append(link);
          output?.append(row);
        }
      });
    </script>
  </body>
</html>
